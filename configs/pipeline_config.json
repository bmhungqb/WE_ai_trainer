{
  "data_pipeline": {
    "gcs_buckets": [
      {
        "gcs_name": "jetson-textile-storage",
        "start": "2026-04-19",
        "end": "2026-04-20",
        "is_require_anno_file": true
      },
      {
        "gcs_name": "vv3-shadow-data",
        "start": "2026-04-19",
        "end": "2026-04-20",
        "is_require_anno_file": false
      }
    ],  
    "verify_configs": {
      "quality_threshold": 0.8,
      "confidence_threshold": 0.75,
      "voting_method": "majority_voting",
      "models": [
        {
          "model_type": "rfdetrMedium",
          "weight_path": "model_weight/rfdetrmedium_0.pth"  
        },
        {
          "model_type": "rfdetrXLarge",
          "weight_path": "model_weight/rfdetrxlarge_0.pth"  
        }
      ]
    },
    "output_configs": {
      "gcs_destination": "textile-datasets/datasets/dataset_auto_training"
    }
  },
  "training_pipeline": {
    "mixing_ratio": {
      "new_data_ratio": 0.4,
      "old_data_ratio": 0.6,
      "train_val_test_split": [
        0.8,
        0.15,
        0.05
      ],
      "stratified_sampling": true
    },
    "ai_trainer_configs":{
      "optuna": {
        "enabled": true,
        "n_trials": 10,
        "sampler": "TPESampler"
      },
      "knowledge_distillation": {
        "enabled": true,
        "teacher_model": "old_model",
        "distillation_temperature": 3.0,
        "alpha": 0.5
      },
      "training": {
        "batch_size": 32,
        "epochs": 50,
        "learning_rate": 0.001,
        "weight_decay": 1e-5,
        "dropout": 0.5,
        "optimizer": "Adam"
      },
      "model_versions": 3
    },
    "evaluation_configs":{
      "metrics": [
        "accuracy",
        "precision",
        "recall",
        "f1_score",
        "confusion_matrix",
        "roc_auc"
      ]
    }
  },
  "logging": {
    "log_dir": "./logs",
    "log_level": "DEBUG",
    "file_format": "detailed",
    "console_format": "simple",
    "max_bytes": 10485760,
    "backup_count": 5
  }
}